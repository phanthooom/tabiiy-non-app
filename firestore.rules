rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Функция проверки, авторизован ли пользователь как админ
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@tabiiy-non.uz';
    }

    // ── Products ──────────────────────────
    match /products/{productId} {
      allow read: if true; // Все могут видеть товары
      allow write: if isAdmin(); // Только админ может добавлять/изменять товары
    }

    // ── Users ──────────────────────────────
    match /users/{userId} {
      allow read, write: if true; // Разрешаем клиентам (без Firebase Auth) читать и писать профили
    }

    // ── Carts ─────────────────────────────
    match /carts/{userId} {
      allow read, write: if true; // Разрешаем клиентам (без Firebase Auth) обновлять корзины
    }

    // ── Settings ──────────────────────────
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Orders ────────────────────────────
    match /orders/{orderId} {
      // Разрешаем всем читать, создавать и обновлять заказы
      // Так как мы отключили Firebase Auth и Cloud Functions, 
      // безопасность обеспечивается тем, что админка скрыта в Telegram боте.
      allow read, create, update: if true; 
      allow delete: if false;
    }
  }
}
