rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Products — читают все, пишет только admin ──────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // управляется через Admin SDK / seed script
    }

    // ── Users — FCM токены, пишет сам клиент ──────────────────────────────
    match /users/{telegramId} {
      allow read, write: if true; // нет Firebase Auth, клиент сохраняет FCM токен
    }

    // ── Carts — не используется (корзина в backend) ───────────────────────
    match /carts/{telegramId} {
      allow read, write: if false;
    }

    // ── Orders — создаёт клиент, читают все (фильтр по telegram_id в запросе)
    match /orders/{orderId} {
      allow create: if true;   // CheckoutPage пишет копию после backend заказа
      allow read:   if true;   // useFirebaseOrders фильтрует по telegram_id
      allow update: if true;   // admin panel обновляет статус
      allow delete: if false;
    }
  }
}
